    "n = input('enter any number')\n",
    "sum = 0 \n",
    "for i in n: \n",
    "    sum = sum+int(i)**3 \n",
    "if sum == int(n) :\n",
    "    print(\"armstrong number\") \n",
    "else:\n",
    "    print(\"not a armstrong number\")"
